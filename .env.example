# ─── Gemini / Vertex AI (preferred backend) ──────────────────────────────
# Paste the entire Service Account JSON as a single-line string. The
# proxy will JSON.parse it on the server. NEVER commit the actual value.
GCP_SA_KEY='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"..."}'
GCP_PROJECT_ID=your-gcp-project-id
# Optional. Default "global" — required for Gemini 3.x. Use a regional
# value (e.g. "us-central1") only when pinning to a 2.5-era model.
GCP_REGION=global

# ─── Gemini direct API key (fallback only) ───────────────────────────────
# Used when GCP_SA_KEY/GCP_PROJECT_ID are absent. Prefer Vertex above.
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Google Cloud Speech-to-Text (separate API key) ──────────────────────
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here

# ─── ElevenLabs TTS ──────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
