modules = ["nodejs-20", "python-3.12", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Flask Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Flask Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python flask_server.py"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 24678
externalPort = 3000

[deployment]
deploymentTarget = "vm"
run = ["bash", "start.sh"]
build = ["npm", "run", "build"]

[userenv]

[userenv.shared]
CLAUDE_CODE_USE_FOUNDRY = "1"
ANTHROPIC_FOUNDRY_BASE_URL = "https://claudeopus67-resource.services.ai.azure.com/anthropic"
ANTHROPIC_DEFAULT_OPUS_MODEL = "claude-opus-4-7"
ANTHROPIC_DEFAULT_SONNET_MODEL = "claude-opus-4-7"
ANTHROPIC_DEFAULT_HAIKU_MODEL = "claude-opus-4-7"
CLAUDE_MODEL = "claude-opus-4-7"
